{
  "expo": {
    "name": "TaskBoard",
    "slug": "taskboard",
    "scheme": "taskboard",
    "version": "1.1.0",
    "orientation": "portrait",
    "icon": "./assets/icon.png",
    "userInterfaceStyle": "automatic",
    "splash": {
      "image": "./assets/splash-icon.png",
      "resizeMode": "contain",
      "backgroundColor": "#F2F2F7"
    },
    "ios": {
      "supportsTablet": true,
      "bundleIdentifier": "com.yuotsuka.taskboard",
      "buildNumber": "27",
      "infoPlist": {
        "NSUserNotificationUsageDescription": "タスクの締切前にリマインダー通知をお送りします。",
        "UIBackgroundModes": ["remote-notification"],
        "CFBundleDisplayName": "かんたんタスクカレンダー"
      },
      "privacyManifests": {
        "NSPrivacyAccessedAPITypes": [
          {
            "NSPrivacyAccessedAPIType": "NSPrivacyAccessedAPICategoryUserDefaults",
            "NSPrivacyAccessedAPITypeReasons": ["CA92.1"]
          }
        ]
      }
    },
    "android": {
      "adaptiveIcon": {
        "backgroundColor": "#E6F4FE",
        "foregroundImage": "./assets/android-icon-foreground.png",
        "backgroundImage": "./assets/android-icon-background.png",
        "monochromeImage": "./assets/android-icon-monochrome.png"
      },
      "package": "com.yuotsuka.taskboard"
    },
    "web": {
      "favicon": "./assets/favicon.png"
    },
    "extra": {
      "supportUrl": "https://15yotsuka.github.io/Task-Board/"
    },
    "plugins": [
      "expo-router",
      [
        "expo-notifications",
        {
          "icon": "./assets/icon.png",
          "color": "#007AFF",
          "sounds": []
        }
      ]
    ]
  }
}
